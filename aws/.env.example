# AWS Lightsail Deployment Configuration
# Copy this file to .env and update with your values

# AWS Configuration
INSTANCE_NAME=honey-talker-prod
REGION=us-east-1
KEY_PAIR_NAME=honey-talker-key
SSH_KEY_PATH=$HOME/.ssh/honey-talker-key.pem

# Domain Configuration (optional - leave as is if not using custom domain)
DOMAIN_NAME=your-domain.com

# Application Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=stepfun/step-3.5-flash:free
SYSTEM_PROMPT=You are a helpful assistant.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=talker-ai

# Database Configuration
MONGODB_URL=mongodb://localhost:27017/honey-talker

# Email for SSL certificate (if using custom domain)
SSL_EMAIL=admin@your-domain.com
